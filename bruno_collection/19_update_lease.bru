meta {
  name: Create Lease
  type: http
  seq: 18
}

post {
  url: {{baseUrl}}/properties/{{propertyId}}/leases
  body: json
  auth: none
}

body:json {
  {
    "tenantId": "{{tenantId}}",
    "startDate": "2026-06-01",
    "endDate": "2027-05-31",
    "rentAmount": 1850
  }
}

assert {
  res.status: eq 201
}
