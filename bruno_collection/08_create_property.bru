meta {
  name: Create Property
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/properties
  body: json
}

body:json {
  {
    "address": "123 Main Street",
    "status": "vacant",
    "rentAmount": 1200,
    "bedrooms": 3,
    "yearbuilt": 2005,
    "imageUrl": "https://example.com/property.jpg"
  }
}

assert {
  res.status: eq 201
}