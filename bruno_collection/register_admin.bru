meta {
  name: Register Admin
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/register
  body: json
  auth: none
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}",
    "displayName": "Scooter",
    "role": "admin"
  }
}

assert {
  res.status: eq 201
}
                 