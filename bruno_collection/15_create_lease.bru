meta {
  name: Create Lease
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/properties/{{propertyId}}/leases
  body: json
  auth: none
}

params:query {
  : 
}

body:json {
  {
    "tenantId": "{{tenantId}}",
    "startDate": "2026-06-01",
    "endDate": "2027-05-31",
    "rentAmount": 1200
  }
}

assert {
  res.status: eq 201
}

script:post-response {
  bru.setVar("leaseId", res("leaseId"))
}
