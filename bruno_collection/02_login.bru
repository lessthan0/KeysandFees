meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/login
  body: json
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}"
  }
}

tests {
 test("login sets cookie", function() {
    expect(res.getHeader("set-cookie")).to.exist
  })
}

assert {
  res.status: eq 200
}