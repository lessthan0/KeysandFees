meta {
  name: Create Rent Payment
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/leases/{{leaseId}}/payments
  body: json
}

body:json {
  {
    "rentMonth": "2026-06",
    "rentAmountPaid": 1200,
    "paidAt": "2026-06-05T12:00:00.000Z",
    "late": false,
    "notes": "Paid in full"
  }
}

script:post-response {
  bru.setVar("paymentId", res.body.paymentId);
}

assert {
  res.status: eq 201
}