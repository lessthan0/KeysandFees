meta {
  name: Create Tenant
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/api/tenants
  body: json
}

body:json {
  {
    "firstName": "John",
    "lastName": "Doe",
    "email": "john@example.com",
    "phone": "555-123-1123",
    "maritalStatus": "single",
    "notes": "Hates dogs and hats"
  }
}


script:post-response {
  console.log(res.body)
  bru.setVar("tenantId", res("tenantId"))
}

assert {
  res.status: eq 201
}